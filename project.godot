[application]

name="色彩消除大挑战"
main_scene="res://scenes/main_menu/MainMenu.tscn"
icon="res://assets/icon.png"

[autoload]

GameState="*res://scripts/managers/GameState.gd"
SoundManager="*res://scripts/managers/SoundManager.gd"
AnalyticsManager="*res://scripts/managers/AnalyticsManager.gd"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/stretch/mode="2d"
window/stretch/aspect="keep"
